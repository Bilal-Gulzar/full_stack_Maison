# Frontend (browser-safe — VITE_ prefix exposes them)
VITE_SANITY_PROJECT_ID="fa5izbm6"
VITE_SANITY_DATASET=production
VITE_SANITY_API_VERSION=2024-01-01
VITE_GOOGLE_CLIENT_ID=

# Backend (server-only — used by /api/* serverless functions)
SANITY_PROJECT_ID=
SANITY_DATASET=production
SANITY_API_VERSION=2024-01-01
SANITY_WRITE_TOKEN=

# 64+ char random hex. Generate: openssl rand -hex 48
JWT_SECRET=

# Resend (https://resend.com) free tier
RESEND_API_KEY="
RESEND_FROM=Maison <Maisonclothing0@gmail.com>

# Google OAuth — https://console.cloud.google.com -> APIs & Services -> Credentials

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

ADMIN_EMAIL=
APP_URL=http://localhost:3000

# Google reCAPTCHA v2 ("I'm not a robot" checkbox) — https://www.google.com/recaptcha/admin
# Leave blank to disable captcha (server treats missing token as OK)
VITE_RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET=

# Veriphone — phone number verification (free 1k/mo at https://veriphone.io)
# Leave blank to skip server-side phone verification (client-side libphonenumber check still runs)
VERIPHONE_API_KEY=

# Abstract API — email reputation (https://docs.abstractapi.com/api/email-reputation)
# Leave blank to skip email validation (basic format check still runs)
ABSTRACT_EMAIL_API_KEY=

# Nodemailer / Gmail (alternative to Resend) — see api/_lib/email.ts
NODMAILER_API_KEY=

# Sanity webhook secret — set the same value in the Sanity dashboard
# webhook config (header "x-webhook-secret") and here. Protects
# /api/orders/status-webhook from unauthorized calls.
SANITY_WEBHOOK_SECRET=
